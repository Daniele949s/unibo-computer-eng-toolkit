--------------------------------SERVER
table ip filter {
	chain OUTPUT {
		type filter hook output priority 0; policy drop;
		#1
		oif eth1 tcp sport 25 ct state established accept
		
		#2
		oif eth1 ip saddr 192.168.1.7 ip daddr 192.168.1.1 tcp dport 22 accept
		
		oif "lo" accept
		oif "eth0" accept
	}
	
	chain INPUT {
		type filter hook input priority 0; policy drop;
		#1
		iif eth1 ip daddr 192.168.1.7 tcp dport 25 accept
		
		#2
		iif eth1 ip saddr 192.168.1.1 ip daddr 192.168.1.7 tcp sport 22 ct state established accept
		
		iif "lo" accept
		iif "eth0" accept
	}
}
--------------------ROUTER
table nat {
	#serve quando devo cambiare il destinatario di un pacchetto, tipicamente per pacchetti provenienti da internet verso host interni
        chain PREROUTING {
                type nat hook prerouting priority dstnat;
                #2
                iif eth2 ip saddr 192.168.1.7 ip daddr 192.168.1.1 dnat to 10.20.0.100
        }
        
        #serve quando devo cambiare la sorgente di un pacchetto, tipicamente per pacchetti provenienti da host interni (in rete privata) verso internet
        chain POSTROUTING {
                type nat hook postrouting priority 100 \;
                #1
                iif eth1 oif eth3 ip saddr 10.20.0.0/22 snat to 130.136.1.1
        }
}

table ip filter {
	chain FORWARD {
		type filter hook forward priority 0; policy drop;
		#1
		iif eth3 oif eth2 ip daddr 192.168.1.7 tcp dport 25 accept
		iif eth2 oif eth3 ip saddr 192.168.1.7 tcp sport 25 ct state established accept
		
		#2
		iif eth2 oif eth1 ip saddr 192.168.1.7 ip daddr 10.20.0.100 tcp dport 22 accept
		iif eth1 oif eth2 ip saddr 10.20.0.100 ip daddr 192.168.1.7 tcp sport 22 ct state established accept
		
		#3
		iif eth1 oif eth3 ip saddr 10.20.0.0/22 accept
		iif eth3 oif eth1 ip daddr 10.20.0.0/22 ct state established accept
	}
}
